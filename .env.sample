# Copy to .env for local runs. Never commit real keys.
API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_VECTOR_STORE_ID=
OPENAI_VECTOR_STORE_NAME=optibot-help-center
OPENAI_ASSISTANT_ID=
OPENAI_CHAT_MODEL=gpt-4o-mini

CHAT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FILE_SEARCH_STORE_NAME=
GEMINI_FILE_SEARCH_STORE_DISPLAY_NAME=optibot-help-center
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2

OPTISIGNS_HELP_CENTER_URL=https://support.optisigns.com
ZENDESK_LOCALE=en-us
ARTICLE_LIMIT=30
UPLOAD_ENABLED=false
UPLOAD_PROVIDER=gemini

OUTPUT_DIR=data/articles
CHUNK_DIR=data/chunks
STATE_FILE=state/articles.json
LOG_DIR=logs
CHUNK_MAX_WORDS=700
HTTP_TIMEOUT_SECONDS=30
